@model RecordEntryListModel

@if (Model.RecordEntries.Any()) {
@if (Model.Pagination.PageCount > 1) {
<div class="pagination">
    @if (Model.Pagination.PageNumber > 1) {
    <a title="Go to previous page of record entries" href="@(Model.UrlPath)pageNumber=@(Model.Pagination.PageNumber - 1)&tag=@Uri.EscapeDataString(Model.Pagination.Tag ?? "")&link=@Model.Pagination.Link&find=@Uri.EscapeDataString(Model.Pagination.Find ?? "")">&laquo;</a>
    }
    @foreach (var pg in Model.Pagination.Pages) {
    @if (pg.IsSelected) {
    <a class="pagination-active">@pg.PageNumber</a>
    } else {
    <a title="Go to record entry page @pg.PageNumber" href="@(Model.UrlPath)pageNumber=@pg.PageNumber&tag=@Uri.EscapeDataString(Model.Pagination.Tag ?? "")&link=@Model.Pagination.Link&find=@Uri.EscapeDataString(Model.Pagination.Find ?? "")">@pg.PageNumber</a>
    }
    @if (pg.IsNextPageSkipped) {
    <a class="skip">&bull;&bull;</a>
    }
    }
    @if (Model.Pagination.PageNumber < Model.Pagination.PageCount) {
    <a title="Go to the next page of record entries" href="@(Model.UrlPath)pageNumber=@(Model.Pagination.PageNumber + 1)&tag=@Uri.EscapeDataString(Model.Pagination.Tag ?? "")&link=@Model.Pagination.Link&find=@Uri.EscapeDataString(Model.Pagination.Find ?? "")">&raquo;</a>
    }
</div>
}
<ul class="srb-list">
    <li class="srb-list">
        <ul class="srb-list-item">
            @foreach (var recordEntry in Model.RecordEntries) {
            <li class="@recordEntry.ListItemCss()">
                <div></div>
                <div class="srb-list-item-entry">
                    <div>
                        <a href="/record/@recordEntry.RecordEntryId">@recordEntry.EntryDate.ToString("dddd dd MMMM yyyy")</a>
                    </div>
                    <div>
                        @recordEntry.Title
                    </div>
                    @if (recordEntry.Amount != null) {
                    <div class="srb-list-item-entry-info">@recordEntry.CcyAmount()</div>
                    }
                    @if (!string.IsNullOrEmpty(recordEntry.Description)) {
                    <div class="srb-list-item-entry-info">@recordEntry.Description</div>
                    }
                    @if (recordEntry.ActiveRecordEntryTags.Any()) {
                    <div class="srb-tag">
                        @foreach (var tag in recordEntry.ActiveRecordEntryTags) {
                        <a href="/?tag=@Uri.EscapeDataString(tag.Tag)">@tag.Tag</a>
                        }
                    </div>
                    }
                </div>
                <div>
                    @if (recordEntry.ReminderDate != null) {
                    <span class="srb-reminder">Reminder set for @recordEntry.ReminderDate.Value.ToString("dddd dd MMMM yyyy")</span>
                    }
                </div>
            </li>
            }
            @if (!string.IsNullOrEmpty(Model.AmountTotal)) {
            <li class="srb-list-item">
                <div></div>
                <div class="srb-list-item-entry">
                    <div></div>
                    <div class="srb-list-item-total">Amount total: @Model.AmountTotal</div>
                </div>
                <div></div>
            </li>
            }
        </ul>
    </li>
</ul>
@if (Model.Pagination.PageCount > 1) {
<div class="pagination">
    @if (Model.Pagination.PageNumber > 1) {
    <a title="Go to previous page of record entries" href="@(Model.UrlPath)pageNumber=@(Model.Pagination.PageNumber - 1)&tag=@Uri.EscapeDataString(Model.Pagination.Tag ?? "")&link=@Model.Pagination.Link&find=@Uri.EscapeDataString(Model.Pagination.Find ?? "")">&laquo;</a>
    }
    @foreach (var pg in Model.Pagination.Pages) {
    @if (pg.IsSelected) {
    <a class="pagination-active">@pg.PageNumber</a>
    } else {
    <a title="Go to record entry page @pg.PageNumber" href="@(Model.UrlPath)pageNumber=@pg.PageNumber&tag=@Uri.EscapeDataString(Model.Pagination.Tag ?? "")&link=@Model.Pagination.Link&find=@Uri.EscapeDataString(Model.Pagination.Find ?? "")">@pg.PageNumber</a>
    }
    @if (pg.IsNextPageSkipped) {
    <a class="skip">&bull;&bull;</a>
    }
    }
    @if (Model.Pagination.PageNumber < Model.Pagination.PageCount) {
    <a title="Go to the next page of record entries" href="@(Model.UrlPath)pageNumber=@(Model.Pagination.PageNumber + 1)&tag=@Uri.EscapeDataString(Model.Pagination.Tag ?? "")&link=@Model.Pagination.Link&find=@Uri.EscapeDataString(Model.Pagination.Find ?? "")">&raquo;</a>
    }
</div>
}
} else {
<p>@Model.NoEntriesMessage</p>
}
